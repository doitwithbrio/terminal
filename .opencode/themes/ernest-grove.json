      "light": "inkSoft",
      "dark": "mossMuted"
    },
    "markdownEmph": {
      "light": "warn",
      "dark": "warnDark"
    },
    "markdownStrong": {
      "light": "forestSoft",
      "dark": "sage200"
    },
    "markdownHorizontalRule": {
      "light": "sage100",
      "dark": "mossBorder"
