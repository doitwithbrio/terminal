      "dark": "mossAccent"
    },
    "secondary": {
      "light": "forest",
      "dark": "mossAccent"
    },
    "accent": {
      "light": "forest",
      "dark": "mossAccent"
    },
    "error": {
      "light": "error",
      "dark": "error"
    },
    "warning": {
      "light": "warn",
      "dark": "warnDark"
    },
    "success": {
      "light": "forest",
      "dark": "mossAccent"
    },
    "info": {
      "light": "info",
      "dark": "info"
    },
    "text": {
      "light": "ink",
      "dark": "mossText"
    },
    "textMuted": {
      "light": "forestSoft",
      "dark": "mossAccent"
