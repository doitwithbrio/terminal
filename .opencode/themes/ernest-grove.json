{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "sage50": "#E4ECE6",
    "sage100": "#D7DED9",
    "sage200": "#C7D1CB",
    "neutral50": "#F0F0F0",
    "paper": "#FFFFFF",
    "borderNeutral": "#E4E4E7",

    "forest": "#1A4731",
    "forestSoft": "#2E5A44",

    "ink": "#09090B",
    "inkSoft": "#5F6B64",

    "mossBg": "#14221A",
    "mossElement": "#2A312D",
    "mossPanel": "#242D27",
    "mossBorder": "#2C4035",
    "mossText": "#E8EEE9",
    "mossMuted": "#A7B4AC",
    "mossAccent": "#8FB39A",

    "warn": "#7D6A35",
