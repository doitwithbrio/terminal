      "light": "forest",
      "dark": "sage200"
    },
    "markdownCodeBlock": {
      "light": "ink",
      "dark": "mossText"
    },
    "syntaxComment": {
      "light": "inkSoft",
      "dark": "mossMuted"
    },
    "syntaxKeyword": {
      "light": "teal",
      "dark": "tealDark"
    },
    "syntaxFunction": {
      "light": "forest",
      "dark": "mossAccent"
    },
    "syntaxVariable": {
      "light": "ink",
      "dark": "mossText"
    },
    "syntaxString": {
      "light": "ochre",
      "dark": "ochreDark"
    },
    "syntaxNumber": {
      "light": "clay",
      "dark": "clayDark"
    },
    "syntaxType": {
      "light": "slate",
      "dark": "slateDark"
    },
    "syntaxOperator": {
      "light": "deepSage",
      "dark": "deepSageDark"
    },
    "syntaxPunctuation": {
      "light": "inkSoft",
      "dark": "mossMuted"
    }
